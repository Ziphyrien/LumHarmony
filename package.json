{
  "name": "lumharmony",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "bun run check && vp build",
    "preview": "vp preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && vp check",
    "check:fix": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && vp check --fix",
    "lint": "vp lint",
    "fmt": "vp fmt . --write",
    "prepare": "vp config --hooks-dir .vite-hooks"
  },
  "dependencies": {
    "apca-w3": "^0.1.9",
    "bits-ui": "^2.18.1",
    "culori": "^4.0.2",
    "lucide-svelte": "^1.0.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "@types/apca-w3": "^0.1.3",
    "@types/node": "^24.10.1",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.1",
    "vite-plus": "^0.2.1"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.1",
    "vitest": "4.1.9"
  }
}
